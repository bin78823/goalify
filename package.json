{
  "name": "goalify",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @goalify/web dev",
    "dev:desktop": "concurrently -k \"pnpm dev\" \"pnpm --filter @goalify/desktop tauri dev\"",
    "dev:web": "pnpm --filter @goalify/web dev",
    "dev:tauri": "pnpm --filter @goalify/desktop tauri dev",
    "dev:ios": "cd packages/mobile && npx expo run:ios",
    "dev:android": "cd packages/mobile && npx expo run:android",
    "dev:mobile": "concurrently -k \"pnpm dev:ios\" \"pnpm dev:android\"",
    "dev:all": "concurrently -k \"pnpm dev\" \"pnpm dev:mobile\"",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @goalify/web build",
    "build:desktop": "pnpm --filter @goalify/desktop tauri build",
    "build:ios": "cd packages/mobile && npx expo run:ios --configuration Release",
    "build:android": "cd packages/mobile && npx expo run:android --variant release",
    "prebuild:ios": "cd packages/mobile && npx expo prebuild --platform ios",
    "prebuild:android": "cd packages/mobile && npx expo prebuild --platform android",
    "prebuild": "cd packages/mobile && npx expo prebuild",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "concurrently": "^9.2.1",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
