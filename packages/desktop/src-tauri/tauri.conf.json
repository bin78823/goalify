{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Goalify",
  "version": "1.0.0",
  "identifier": "com.goalify.app",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter @goalify/web build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 24
        }
      }
    ],
    "security": {
      "capabilities": [
        {
          "identifier": "main-window-capability",
          "description": "Permissions for the main window",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "core:window:allow-is-fullscreen",
            "core:window:allow-set-fullscreen",
            "core:window:allow-set-simple-fullscreen",
            "core:window:allow-is-maximized",
            "core:window:allow-maximize",
            "core:window:allow-unmaximize",
            "core:window:allow-start-dragging"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
